# Claude API（必填）
# 官方地址：https://console.anthropic.com/
# 或第三方代理（如 wolfai.top）的 key
ANTHROPIC_API_KEY=sk-ant-你的key或代理key

# 如果使用第三方代理（如 wolfai.top），填代理的 base URL
# 使用官方 Anthropic 则不填此项
ANTHROPIC_BASE_URL=https://wolfai.top/v1

# 图片生成 API（必填）
# 获取地址：https://apicore.ai/
IMAGE_API_KEY=sk-your-key-here
IMAGE_API_BASE=https://api.apicore.ai/v1
IMAGE_MODEL=gemini-2.5-flash-image-hd
